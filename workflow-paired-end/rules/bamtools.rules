from snakemake.exceptions import MissingInputException

"""
Rules for generating alignmnet statistics with bamtools. 
"""


rule bamtools:
    input:
        bam = "reads/{scientific_name}/{library_strategy}/{sample_accession}/{prefix}.trim.aln.sort.bam",

    output:
        stats = "reads/{scientific_name}/{library_strategy}/{sample_accession}/{prefix}.trim.aln.sort.bamtools"
        
    shell:
        "{config[BIN][bamtools]} stats -in {input.bam} > {output.stats}"
        

