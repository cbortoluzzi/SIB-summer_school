from snakemake.exceptions import MissingInputException

"""
Rules for indexing the reference genome with bwa-mem2. 
"""

rule bwa_index:
    input:
        fasta = "genomes/{scientific_name}/{assembly}.fasta"
    
    output:
        "genomes/{scientific_name}/{assembly}.fasta.amb",
        "genomes/{scientific_name}/{assembly}.fasta.ann",
        "genomes/{scientific_name}/{assembly}.fasta.bwt.2bit.64",
        "genomes/{scientific_name}/{assembly}.fasta.pac",
        "genomes/{scientific_name}/{assembly}.fasta.0123"
    
    threads: 8
    
    shell:
        "{config[BIN][bwa-mem2]} index {input.fasta}"

