"""
Rules for trimming fastq files with Fastp.
"""


rule fastp:
    input:
        r1 = lambda wildcards: REFORMAT_READS[wildcards.prefix]["reads"][0],
        r2 = lambda wildcards: REFORMAT_READS[wildcards.prefix]["reads"][1],

    params:
        output_dir = "reads/{scientific_name}/{library_strategy}/{sample_accession}"

    output:
        html = "reads/{scientific_name}/{library_strategy}/{sample_accession}/{prefix}_fastp.html",
        json = "reads/{scientific_name}/{library_strategy}/{sample_accession}/{prefix}_fastp.json",
        r1  = "reads/{scientific_name}/{library_strategy}/{sample_accession}/{prefix}_1.trim.fastq.gz",
        r2  = "reads/{scientific_name}/{library_strategy}/{sample_accession}/{prefix}_2.trim.fastq.gz"        

    threads: 16

    shell:
        "{config[BIN][fastp]} -i {input.r1} -I {input.r2} -o {output.r1} -O {output.r2} --detect_adapter_for_pe -q {config[qualified_quality_phred]} -u {config[unqualified_percent_limit]} -l {config[length_required]} -n {config[n_base_limit]} -g -t {threads} -h {output.html} -j {output.json}"
