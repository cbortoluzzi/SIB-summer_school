"""
Rules for trimming fastq files with Fastp.
"""


def get_species(wildcards):
    species = all_reads[wildcards.prefix]["species"]
    return species


rule fastp:
    input:
        r1 = lambda wildcards: all_reads[wildcards.prefix]["reads"][0],
        r2 = lambda wildcards: all_reads[wildcards.prefix]["reads"][1]

    params:
        species = get_species

    output:
        html = "results/{species}/fastp/{prefix}_fastp.html",
        json = "results/{species}/fastp/{prefix}_fastp.json",
        r1 = "results/{species}/fastp/{prefix}_1.trim.fastq.gz",
        r2 = "results/{species}/fastp/{prefix}_2.trim.fastq.gz",
        
    threads: 16

    shell:
        "{config[bin][fastp]} -i {input.r1} -I {input.r2} -o {output.r1} -O {output.r2} -q {config[qualified_quality_phred]} -u {config[unqualified_quality_phred]} -l {config[min_length_required]} -g -t {threads} -h {output.html} -j {output.json}"

