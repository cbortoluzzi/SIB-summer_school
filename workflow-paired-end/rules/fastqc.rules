"""
Rules for checking the quality of a FASTQ file.
"""

def get_fastq(wildcards):
    reads = all_reads[wildcards.prefix]["reads"]
    return reads


rule fastqc:
    input:
        reads = get_fastq

    params:
        output = "results/{species}/fastqc"

    output:
        html_r1 = "results/{species}/fastqc/{prefix}_1_fastqc.html",    
        html_r2 = "results/{species}/fastqc/{prefix}_2_fastqc.html",
        zip_r1  = "results/{species}/fastqc/{prefix}_1_fastqc.zip",
        zip_r2  = "results/{species}/fastqc/{prefix}_2_fastqc.zip"
        
    threads: 16

    shell:
        """
        mkdir -p {params.output}
        {config[bin][fastqc]} {input.reads} -t {threads} -o {params.output} -dir /tmp
        """

