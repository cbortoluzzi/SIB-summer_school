"""
Rules for aligning reads to the reference genome with bwa-mem2, mark duplicates with samblaster, sort and index with samtools. 
"""


def get_assembly(wildcards):
    scientific_name = REFORMAT_READS[wildcards.prefix]["scientific_name"]
    reference_species = MATCH[scientific_name]
    assembly = GENOME_BY_SPECIES[reference_species]
    if reference_species:
        return f"genomes/{reference_species}/{assembly}.fasta"
    else:
        return f"genomes/{scientific_name}/{assembly}.fasta"



rule bwa_mem2:
    input:
        ref = get_assembly,
        r1  = "reads/{scientific_name}/{library_strategy}/{sample_accession}/{prefix}_1.trim.fastq.gz",
        r2  = "reads/{scientific_name}/{library_strategy}/{sample_accession}/{prefix}_2.trim.fastq.gz"        


    params:
        idx = lambda wildcards: REFORMAT_READS[wildcards.prefix]["idx"],
        plateform = lambda wildcards: REFORMAT_READS[wildcards.prefix]["instrument_platform"],

    output:
        bam = "reads/{scientific_name}/{library_strategy}/{sample_accession}/{prefix}.trim.aln.bam",
        sorted_bam = "reads/{scientific_name}/{library_strategy}/{sample_accession}/{prefix}.trim.aln.sort.bam",
        
                
    threads: 16
        
    shell:
        """
        {config[BIN][bwa-mem2]} mem -R '@RG\\tID:{params.idx}\\tPL:{params.plateform}\\tSM:{wildcards.prefix}\\tLB:lib_{params.idx}\\tPU:pu_{params.idx}\' \
        -M -T {config[min_score]} -t {threads} \
        {input.ref} {input.r1} {input.r2}  \
        | {config[BIN][samblaster]} -M \
        | {config[BIN][samtools]} view -Sb -@ {threads} > {output.bam}
        {config[BIN][samtools]} sort -t {threads} -m 2G -o {output.sorted_bam} {output.bam}
        {config[BIN][samtools]} index -@ {threads} {output.sorted_bam}
        """
        
