rule download_fastq:
    wildcard_constraints:
        filename = r"(?!.*trim).+\.fastq\.gz"
    output:
        "reads/{scientific_name}/{library_strategy}/{sample_accession}/{filename}"
    params:
        url = lambda wildcard, output: FASTQ_URL_MAP[output[0]]
    shell:
        "curl -L -o {output} {params.url}"


rule download_genome:
    wildcard_constraints:
        filename = r".+\.fasta"
    output:
        "genomes/{scientific_name}/{filename}"
    params:
        url = lambda wc, output: GENOME_URL_MAP[output[0]]
    shell:
        "curl -L -o {output} {params.url}"



