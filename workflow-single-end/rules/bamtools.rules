from snakemake.exceptions import MissingInputException

"""
Rules for generating alignmnet statistics with bamtools. 
"""


rule bamtools:
    input:
        bam = "results/{species}/bwa-mem/{name}.aln.sort.bam"

    output:
        bam_stats = "results/{species}/bamtools/{name}.aln.sort.bamtools"
        
    shell:
        "{config[bin][bamtools]} stats -in {input.bam} > {output.bam_stats}"
