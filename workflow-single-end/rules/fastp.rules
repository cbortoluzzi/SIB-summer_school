"""
Rules for trimming fastq files with Fastp.
"""

def get_fastq(wildcards):
    reads = all_reads[wildcards.prefix]["reads"]
    return reads


def get_species(wildcards):
    species = all_reads[wildcards.prefix]["species"]
    return species


rule fastp:
    input:
        reads = get_fastq

    params:
        species = get_species

    output:
        html = "results/{species}/fastp/{prefix}_fastp.html",
        json = "results/{species}/fastp/{prefix}_fastp.json",
        r = "results/{species}/fastp/{prefix}.trim.fastq.gz"
        
    threads: 16

    shell:
        "{config[bin][fastp]} -i {input.reads} -o {output.r} -q {config[qualified_quality_phred]} -u {config[unqualified_quality_phred]} -l {config[min_length_required]} -g -t {threads} -h {output.html} -j {output.json}"
